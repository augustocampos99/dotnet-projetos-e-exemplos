{
  "openapi": "3.1.1",
  "info": {
    "title": "PagamentoMensageria.Web | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5166"
    }
  ],
  "paths": {
    "/api/pagamentos": {
      "post": {
        "tags": [
          "Pagamento"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Pagamento"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Pagamento"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Pagamento"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Pagamento": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "nomePagador": {
            "type": "string"
          },
          "numeroCartao": {
            "type": "string"
          },
          "digitoVerificador": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "mesVencimento": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "anoVencimento": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "valor": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Pagamento"
    }
  ]
}